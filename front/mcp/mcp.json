{
  "mcpServers": {
    "lm-mcp-server": {
      "type": "stdio",
      "timeout": 60000,
      "command": "node",
      "args": [
        "d:/work/ai-future/front/mcp/front-mcp/dist/index.js"
      ],
      "cwd": "d:/work/ai-future/front/mcp/front-mcp"
    },
    "gitnexus": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "gitnexus",
        "mcp"
      ]
    },
    "chrome-devtools": {
      "command": "npx",
      "args": [
        "--registry",
        "https://registry.npmjs.org",
        "chrome-devtools-mcp@0.21.0"
      ]
    },
    "fetch": {
      "command": "uvx",
      "args": [
        "mcp-server-fetch"
      ]
    },
    "mind-map": {
      "command": "npx",
      "args": [
        "@lucianaib/mind-map-mcp"
      ]
    },
    "drawio-mcp": {
      "command": "npx",
      "args": [
        "@drawio/mcp@latest"
      ]
    },
    "Framelink MCP for Figma": {
      "command": "D:\\software\\front\\node\\v20.18.0\\node.exe",
      "args": [
        "D:\\software\\front\\node\\v20.18.0\\node_modules\\npm\\bin\\npx-cli.js",
        "-y",
        "figma-developer-mcp",
        "--figma-api-key=${FIGMA_API_KEY}",
        "--stdio"
      ]
    }
  }
}